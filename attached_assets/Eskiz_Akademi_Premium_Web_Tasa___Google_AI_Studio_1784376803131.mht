.v3-font-headline-2 { font-family: Inter, sans-serif; font-optical-sizing: auto; font-size: 16px; font-weight: 500; line-height: 24px; }

.v3-font-label { font-family: Inter, sans-serif; font-optical-sizing: auto; font-size: 12px; font-weight: 400; line-height: 18px; }

.v3-font-label-thin { font-family: Inter, sans-serif; font-optical-sizing: auto; font-size: 12px; font-weight: 400; line-height: 16px; }

